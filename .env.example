# ClankerStudios environment template.
# Copy to `.env` and fill in whatever you actually need.
# `.env` is gitignored; `.env.example` is not.
#
# Nothing here is read automatically — the scripts call os.getenv at
# use time. If a key is missing, the feature that needs it fails soft
# (TTS) or raises when the backend is invoked (OpenAI).

# --- OpenAI -------------------------------------------------------------------
# Used by src/llm/openai_backend.py. Required — every config calls OpenAI.
OPENAI_API_KEY=

# --- ElevenLabs TTS (only when audio_enabled: true) ---------------------------
# Used by src/tts/elevenlabs.py. The voice_id itself lives in the run config
# (configs/*.yaml → elevenlabs_voice_id), not here.
ELEVENLABS_API_KEY=

# --- DashScope i2v (only when video_enabled: true) ----------------------------
# Used by src/i2v/dashscope.py to render clips with Alibaba Wan models.
# Endpoint defaults to the international gateway; override only if you've been
# issued a region-specific URL by Alibaba.
DASHSCOPE_API_KEY=
DASHSCOPE_ENDPOINT_URL=https://dashscope-intl.aliyuncs.com/api/v1
